<% layout('layout') %>

<% if (locals.error_msg && error_msg.length > 0) { %>
    <div style="background: rgba(239, 68, 68, 0.1); color: #f87171; padding: 1rem; border-radius: 8px; margin-bottom: 2rem; border: 1px solid rgba(239,68,68,0.2);">
        <%= error_msg %>
    </div>
    <script>
        setTimeout(() => alert(<%- JSON.stringify(error_msg.join('\\n')) %>), 300);
    </script>
<% } %>
<% if (locals.success_msg && success_msg.length > 0) { %>
    <div style="background: rgba(34, 197, 94, 0.1); color: #4ade80; padding: 1rem; border-radius: 8px; margin-bottom: 2rem; border: 1px solid rgba(34,197,94,0.2);">
        <%= success_msg %>
    </div>
    <script>
        setTimeout(() => alert(<%- JSON.stringify(success_msg.join('\\n')) %>), 300);
    </script>
<% } %>

<div class="user-header glass-card" style="margin-bottom: 2rem;">
    <h2>Available Books</h2>
    <p style="color: var(--text-gray);">Browse and find books to borrow from our campus library.</p>
</div>

<div class="books-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
    <% if (books.length === 0) { %>
        <div class="glass-card" style="grid-column: 1/-1; text-align: center; padding: 3rem;">
            <p style="color: var(--text-gray);">No books currently available for borrowing.</p>
        </div>
    <% } else { %>
        <% books.forEach(book => { %>
            <div class="glass-card book-card" style="display: flex; flex-direction: column; height: 100%;">
                <div style="background: rgba(255,255,255,0.05); height: 150px; border-radius: 8px; margin-bottom: 1rem; display: flex; align-items: center; justify-content: center; font-size: 3rem;">
                    📚
                </div>
                <h4 style="margin: 0 0 0.5rem 0;"><%= book.name %></h4>
                <p style="font-size: 0.85rem; color: var(--text-gray); margin-bottom: 0.5rem;">ID: <%= book.bookId %></p>
                <p style="font-size: 0.9rem; margin-bottom: 1.5rem; flex-grow: 1;">Available: <span class="badge" style="background: var(--success); color: white;"><%= book.availableQuantity %></span></p>
                <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 1rem;">
                    <span style="font-weight: 600; color: var(--primary);">Rs. <%= book.ratePerQuantity %></span>
                    <% if (locals.requestedBookIds && requestedBookIds.includes(book.bookId)) { %>
                        <button class="btn" style="padding: 0.5rem 1rem; font-size: 0.8rem; background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245,158,11,0.3); color: #f59e0b; cursor: not-allowed;" disabled>Request Pending</button>
                    <% } else { %>
                        <form action="/user/request-book/<%= book.bookId %>" method="POST" style="margin:0">
                            <button type="submit" class="btn btn-primary" style="padding: 0.5rem 1rem; font-size: 0.8rem;">Request Book</button>
                        </form>
                    <% } %>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>
