<% layout('layout') %>

<div class="user-header glass-card" style="margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto; text-align: center;">
    <h2>Contact Admin</h2>
    <p style="color: var(--text-gray);">Need help or have questions? Reach out to the library administration.</p>
</div>

<div class="glass-card" style="max-width: 600px; margin: 0 auto;">
    <form action="#" method="GET">
        <div class="form-group">
            <label>Subject</label>
            <input type="text" placeholder="Enter your query subject..." required>
        </div>
        <div class="form-group">
            <label>Message</label>
            <textarea placeholder="Write your message here..." rows="5" required style="width: 100%; padding: 0.8rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.2); color: white;"></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.8rem;" onclick="event.preventDefault(); alert('Message sent successfully!');">Send Message</button>
    </form>
    
    <div style="margin-top: 2.5rem; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 1.5rem; text-align: center;">
        <h4 style="margin-bottom: 1rem; color: var(--primary);">Other Contact Information</h4>
        <p style="color: var(--text-gray); margin-bottom: 0.5rem;"><strong>Email:</strong> admin@campuslibrary.edu</p>
        <p style="color: var(--text-gray); margin-bottom: 0.5rem;"><strong>Phone:</strong> +1 (555) 123-4567</p>
        <p style="color: var(--text-gray);"><strong>Hours:</strong> Mon - Fri, 9:00 AM - 5:00 PM</p>
    </div>
</div>
